{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**/*",
      "use": "@vercel/static"
    }
  ],
    "redirects": [
    { "source": "/server", "destination": "http://192.168.1.141" },
    { "source": "/adminPanel", "destination": "../client/html/adminPanel.html" },
    { "source": "/catalog", "destination": "../client/html/catalog.html" },
    { "source": "/login", "destination": "../client/html/login.html" },
    { "source": "/member", "destination": "../client/html/member.html" },
    { "source": "/", "destination": "../client/index.html" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/(?!api)",
      "dest": "client/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
